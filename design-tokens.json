{
  "archetype": "premium-brutalist",
  "archetypeLabel": "Premium Brutalist",
  "palette": {
    "primary": "#2C2C2C",
    "accent": "#A34A2A",
    "bg": "#FFFFFF",
    "surface": "#F5F5F5",
    "fg": "#333333"
  },
  "typography": {
    "display": "Merriweather",
    "body": "Lato",
    "scaleRatio": 1.5,
    "sizes": [
      {
        "token": "xs",
        "px": 7
      },
      {
        "token": "sm",
        "px": 11
      },
      {
        "token": "base",
        "px": 16
      },
      {
        "token": "md",
        "px": 24
      },
      {
        "token": "lg",
        "px": 36
      },
      {
        "token": "xl",
        "px": 54
      },
      {
        "token": "2xl",
        "px": 81
      },
      {
        "token": "display",
        "px": 122
      }
    ]
  },
  "motion": {
    "preset": "snap.cut",
    "easing": "cubic-bezier(.2,.8,.2,1)",
    "duration": 220,
    "springs": [
      "stiff",
      "tight"
    ]
  },
  "effects": [
    "1px hairline grid",
    "monospace meta labels",
    "scroll-jacked sections",
    "no shadows"
  ]
